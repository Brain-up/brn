<article role="contentinfo">
  <nav class="flex mb-8 border-b border-gray-200" aria-label="About page navigation">
    <LinkTo
      @route="description.index"
      class="px-6 py-3 text-lg font-semibold border-b-2 transition-colors
        {{if (is-active "description.index") "border-indigo-600 text-indigo-600" "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300"}}"
    >
      {{t "description.tabs.users"}}
    </LinkTo>
    <LinkTo
      @route="description.developers"
      class="px-6 py-3 text-lg font-semibold border-b-2 transition-colors
        {{if (is-active "description.developers") "border-indigo-600 text-indigo-600" "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300"}}"
    >
      {{t "description.tabs.developers"}}
    </LinkTo>
  </nav>

  {{outlet}}
</article>
