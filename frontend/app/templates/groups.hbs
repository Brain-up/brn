{{page-title (t "groups.title")}}
<div class="sm:text-base sm:mt-6 flex justify-center mt-0 text-sm"><h3>{{t
      "groups.exercise_selection"
    }}</h3></div>
<ol
  class="series-container sm:flex-row flex flex-col items-center justify-center mt-3"
>
  <li class="list-item sm:mr-6 mr-0">
    <LinkTo @route="group" @model={{array-last @model}} title={{get (array-last @model) "description"}}>
      <ExerciseType
        @initial={{get (array-last @model) "name"}}
        @img="speech-exercises"
      />
    </LinkTo>
  </li>
  <li class="list-item sm:mt-0 mt-3">
    <LinkTo @route="group" @model={{array-first @model}} title={{get (array-first @model) "description"}}>
      <ExerciseType
        @initial={{get (array-first @model) "name"}}
        @img="non-speech-exercises"
      />
    </LinkTo>
  </li>
</ol>