<section class="header bg-gradient-to-br from-blue-100 to-gray-100">
  <div
    class="lg:py-20 sm:py-16 container relative flex flex-wrap items-center px-4 py-10 mx-auto"
  >
    <div class="lg:w-6/12 w-full">
      <div class="max-w-2xl">
        <p
          class="text-blue-light inline-flex px-4 py-2 text-xs font-bold tracking-wider uppercase bg-white rounded-full"
        >
          {{t "index.hero_badge"}}
        </p>
        <h1
          class="sm:text-5xl mt-6 text-4xl font-semibold leading-tight text-gray-800"
        >
          {{t "index.app_info" htmlSafe=true}}
        </h1>
        <p class="sm:text-xl mt-6 text-lg leading-relaxed text-gray-600">
          {{t "index.app_description"}}
        </p>
        <div class="mt-10">
          <LinkTo
            @route="registration"
            data-test-registration-form
            class="hover:bg-indigo-700 inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white transition-colors bg-indigo-600 rounded-full"
          >
            {{t "index.cta"}}
          </LinkTo>
        </div>
      </div>
    </div>

    <div class="lg:w-6/12 lg:mt-0 w-full mt-10">
      <div class="md:grid-cols-2 grid gap-4">
        <div
          class="md:col-span-2 sm:p-8 flex items-center p-6 bg-white border border-blue-100 rounded-lg shadow-lg"
        >
          <div
            class="sm:w-20 sm:h-20 flex items-center justify-center flex-shrink-0 w-16 h-16 mr-4 bg-blue-100 rounded-full"
          >
            <div class="bg-blue-light w-8 h-8 rounded-full"></div>
          </div>
          <div>
            <p class="text-blue-light text-xs font-bold tracking-wider uppercase">
              {{t "index.visual.child.title"}}
            </p>
            <p class="mt-2 text-base leading-relaxed text-gray-600">
              {{t "index.visual.child.description"}}
            </p>
          </div>
        </div>

        <div class="sm:p-6 p-5 bg-white border border-purple-100 rounded-lg shadow-lg">
          <p class="text-xs font-bold tracking-wider text-purple-500 uppercase">
            {{t "index.visual.adult.title"}}
          </p>
          <p class="mt-3 text-base leading-relaxed text-gray-600">
            {{t "index.visual.adult.description"}}
          </p>
        </div>

        <div class="sm:p-6 p-5 bg-white border border-gray-200 rounded-lg shadow-lg">
          <p class="text-xs font-bold tracking-wider text-gray-700 uppercase">
            {{t "index.visual.senior.title"}}
          </p>
          <p class="mt-3 text-base leading-relaxed text-gray-600">
            {{t "index.visual.senior.description"}}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<AboutUs />
